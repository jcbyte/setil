# Firebase Admin SDK service-account credentials (server-side secrets).
# Current project requires only `PROJECT_ID`, `PRIVATE_KEY`, and `CLIENT_EMAIL`.
FIREBASE_TYPE=
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
# The private key should be written on a single line with line breaks represented as '\n' literals.
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=
FIREBASE_TOKEN_URI=
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=
FIREBASE_CLIENT_X509_CERT_URL=
FIREBASE_UNIVERSE_DOMAIN=

# Server-side AES-256-GCM key used to encrypt bank details.
# This can be generated with: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))`
# Note: changing this will make previously encrypted data unreadable.
ENCRYPTION_KEY=


# Firebase Web SDK configuration (client-side and public by design).
# Note: Vite exposes variables prefixed with VITE_.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional; only needed when Firebase Analytics is enabled.
VITE_FIREBASE_MEASUREMENT_ID=

# Toggle client-side maintenance mode. literal 'true' or 'false'.
# This value is embedded at build time, so we must redeploy after changing it.
VITE_MAINTENANCE=
